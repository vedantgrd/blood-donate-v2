<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/request_card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Section: Request ID, Blood Type, Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_request_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Request ID: BL-5431"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_blood_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Blood Type: O+"
                    android:textColor="#555555"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/status_active_background"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Active"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#EEEEEE" />

        <!-- Bottom Section: Hospital, Date, Button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txt_hospital"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="City Hospital, Ward 3"
                    android:textColor="#555555"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/txt_request_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Requested on: 02 Apr 2025"
                    android:textColor="#777777"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/button_view_details"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/outline_button_background"
                android:paddingHorizontal="12dp"
                android:text="View Details"
                android:textColor="#e74c3c"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>